// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum CategoryKind {
  BIEN
  SERVICE
}

enum FieldType {
  TEXT
  NUMBER
  DATE
}

enum StockStatus {
  EN_STOCK
  EN_ATTENTE
  VENDU
}

enum SaleStatus {
  EN_ATTENTE
  ENCAISSE
  LITIGE
}

enum Priority {
  URGENT
  NORMAL
  PAS_PRESSE
}

enum CategoryScope {
  PRO
  PERSO
}

enum ImportedListingStatus {
  PENDING
  VALIDATED
  REJECTED
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}

model Category {
  id         String   @id @default(cuid())
  name       String
  emoji      String?
  color      String?
  kind       CategoryKind
  scope      CategoryScope @default(PRO)
  hasStock   Boolean  @default(true)
  trackPriorite Boolean @default(false)
  trackRecu     Boolean @default(false)
  trackEvents   Boolean @default(false)
  showDescription Boolean @default(true)
  showCompteEmail Boolean @default(true)
  isBuiltin  Boolean  @default(false)
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  fields       CategoryField[]
  sources      CategorySource[]
  stockItems   StockItem[]
  sales        Sale[]
  events       Event[]
  eventFolders EventFolder[]
}

// Regroupe des événements entre eux (ex: dossier "Coupe du monde" contenant tous les
// matchs) pour pouvoir filtrer/sélectionner le lot en un clic et voir le bénéf cumulé.
model EventFolder {
  id         String   @id @default(cuid())
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  name       String
  createdAt  DateTime @default(now())

  events Event[]

  @@unique([categoryId, name])
}

model Event {
  id            String       @id @default(cuid())
  categoryId    String
  category      Category     @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  name          String
  dateEvenement DateTime?
  lieuSalle     String?
  notes         String?
  folderId      String?
  folder        EventFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  stockItems StockItem[]
  sales      Sale[]

  @@index([categoryId])
  @@index([folderId])
}

model CategoryField {
  id          String    @id @default(cuid())
  categoryId  String
  category    Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  key         String
  label       String
  fieldType   FieldType
  required    Boolean   @default(false)
  showInStock Boolean   @default(true)
  showInSale  Boolean   @default(true)
  sortOrder   Int       @default(0)

  @@unique([categoryId, key])
}

model CategorySource {
  id             String   @id @default(cuid())
  categoryId     String
  category       Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  label          String
  appliesToStock Boolean  @default(true)
  appliesToSale  Boolean  @default(true)
  sortOrder      Int      @default(0)

  @@unique([categoryId, label])
}

model StockItem {
  id               String       @id @default(cuid())
  categoryId       String
  category         Category     @relation(fields: [categoryId], references: [id])
  dateAchat        DateTime
  description      String?
  source           String?
  eventId          String?
  event            Event?       @relation(fields: [eventId], references: [id], onDelete: SetNull)
  qty              Int          @default(1)
  coutAchatUnit    Decimal      @db.Decimal(12, 2)
  prixCibleVente   Decimal?     @db.Decimal(12, 2)
  priorite         Priority?
  recu             Boolean?
  tauxTvaAchat     Decimal      @default(0) @db.Decimal(5, 2)
  dateVente        DateTime?
  dateEncaissement DateTime?
  statut           StockStatus  @default(EN_STOCK)
  compteEmail      String?
  notes            String?
  customValues     Json         @default("{}")
  saleId           String?      @unique
  sale             Sale?        @relation(fields: [saleId], references: [id], onDelete: SetNull)
  deletedAt        DateTime?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@index([categoryId, deletedAt])
  @@index([deletedAt, statut])
}

model Sale {
  id               String      @id @default(cuid())
  categoryId       String
  category         Category    @relation(fields: [categoryId], references: [id])
  dateVente        DateTime
  dateEncaissement DateTime?
  source           String?
  eventId          String?
  event            Event?      @relation(fields: [eventId], references: [id], onDelete: SetNull)
  statut           SaleStatus  @default(ENCAISSE)
  description      String?
  qty              Int         @default(1)
  prixVenteUnit    Decimal     @db.Decimal(12, 2)
  coutAchatUnit    Decimal     @default(0) @db.Decimal(12, 2)
  tauxTvaVente     Decimal     @default(0) @db.Decimal(5, 2)
  tauxTvaAchat     Decimal     @default(0) @db.Decimal(5, 2)
  notes            String?
  customValues     Json        @default("{}")
  stockItem        StockItem?
  deletedAt        DateTime?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  @@index([categoryId, deletedAt])
  @@index([deletedAt, statut])
}

// Billet détecté dans un email de confirmation (Ticketmaster, etc.) via l'import Gmail,
// en attente de validation manuelle avant de devenir un vrai StockItem. Le dédoublonnage
// se fait sur gmailMessageId pour ne jamais réimporter deux fois le même mail.
model ImportedListing {
  id              String                @id @default(cuid())
  provider        String
  gmailMessageId  String                @unique
  status          ImportedListingStatus @default(PENDING)
  numeroCommande  String?
  eventName       String
  eventDate       DateTime?
  lieuSalle       String?
  categorie       String?
  qty             Int
  coutAchatUnit   Decimal               @db.Decimal(12, 2)
  seats           Json
  rawEmailText    String
  createdStockItemIds String[]          @default([])
  createdAt       DateTime              @default(now())
  validatedAt     DateTime?

  @@index([status])
}

model AchatPro {
  id          String   @id @default(cuid())
  dateAchat   DateTime
  description String
  categorie   String?
  qty         Int      @default(1)
  montantHt   Decimal  @db.Decimal(12, 2)
  tauxTva     Decimal  @default(0) @db.Decimal(5, 2)
  notes       String?
  deletedAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([deletedAt])
}

// Dépenses personnelles (hors SASU) : modèle séparé d'AchatPro pour garantir que
// rien ici ne peut jamais se retrouver dans les calculs de TVA/IS (Pro uniquement).
model ChargePerso {
  id          String    @id @default(cuid())
  date        DateTime
  description String
  categorie   String?
  qty         Int       @default(1)
  montant     Decimal   @db.Decimal(12, 2)
  notes       String?
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([deletedAt])
}
