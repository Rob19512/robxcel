// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum CategoryKind {
  BIEN
  SERVICE
}

enum FieldType {
  TEXT
  NUMBER
  DATE
}

enum StockStatus {
  EN_STOCK
  EN_ATTENTE
  VENDU
}

enum SaleStatus {
  EN_ATTENTE
  ENCAISSE
  LITIGE
}

enum Priority {
  URGENT
  NORMAL
  PAS_PRESSE
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}

model Category {
  id         String   @id @default(cuid())
  name       String
  emoji      String?
  color      String?
  kind       CategoryKind
  hasStock   Boolean  @default(true)
  trackPriorite Boolean @default(false)
  trackRecu     Boolean @default(false)
  isBuiltin  Boolean  @default(false)
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  fields     CategoryField[]
  sources    CategorySource[]
  stockItems StockItem[]
  sales      Sale[]
}

model CategoryField {
  id          String    @id @default(cuid())
  categoryId  String
  category    Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  key         String
  label       String
  fieldType   FieldType
  required    Boolean   @default(false)
  showInStock Boolean   @default(true)
  showInSale  Boolean   @default(true)
  sortOrder   Int       @default(0)

  @@unique([categoryId, key])
}

model CategorySource {
  id             String   @id @default(cuid())
  categoryId     String
  category       Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  label          String
  appliesToStock Boolean  @default(true)
  appliesToSale  Boolean  @default(true)
  sortOrder      Int      @default(0)

  @@unique([categoryId, label])
}

model StockItem {
  id               String       @id @default(cuid())
  categoryId       String
  category         Category     @relation(fields: [categoryId], references: [id])
  dateAchat        DateTime
  description      String?
  source           String?
  qty              Int          @default(1)
  coutAchatUnit    Decimal      @db.Decimal(12, 2)
  prixCibleVente   Decimal?     @db.Decimal(12, 2)
  priorite         Priority?
  recu             Boolean?
  tauxTvaAchat     Decimal      @default(0) @db.Decimal(5, 2)
  dateVente        DateTime?
  dateEncaissement DateTime?
  statut           StockStatus  @default(EN_STOCK)
  compteEmail      String?
  notes            String?
  customValues     Json         @default("{}")
  saleId           String?      @unique
  sale             Sale?        @relation(fields: [saleId], references: [id], onDelete: SetNull)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
}

model Sale {
  id               String      @id @default(cuid())
  categoryId       String
  category         Category    @relation(fields: [categoryId], references: [id])
  dateVente        DateTime
  dateEncaissement DateTime?
  source           String?
  statut           SaleStatus  @default(ENCAISSE)
  description      String?
  qty              Int         @default(1)
  prixVenteUnit    Decimal     @db.Decimal(12, 2)
  coutAchatUnit    Decimal     @default(0) @db.Decimal(12, 2)
  tauxTvaVente     Decimal     @default(0) @db.Decimal(5, 2)
  tauxTvaAchat     Decimal     @default(0) @db.Decimal(5, 2)
  notes            String?
  customValues     Json        @default("{}")
  stockItem        StockItem?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
}

model AchatPro {
  id          String   @id @default(cuid())
  dateAchat   DateTime
  description String
  categorie   String?
  qty         Int      @default(1)
  montantHt   Decimal  @db.Decimal(12, 2)
  tauxTva     Decimal  @default(0) @db.Decimal(5, 2)
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
